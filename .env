# Required for live OpenAI responses
OPENAI_API_KEY=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

# Optional. Keep configurable so we can swap models quickly.
OPENAI_MODEL=gpt-4o-mini
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_PROFILE=companion
OPENAI_TTS_VOICE=shimmer
OPENAI_TTS_STYLE=warm and human, expressive but calm, natural phrasing, subtle pauses, never robotic or monotone
OPENAI_TTS_SPEED=0.96
OPENAI_TRANSCRIBE_MODEL=whisper-1
OPENAI_VISION_MODEL=gpt-4o-mini
OPENAI_STT_ENGLISH_ONLY=1

AI_PROVIDER=auto
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b

# Insecure convenience mode for fast Pi prototyping
SCOUT_ADMIN_TOKEN=
SCOUT_FS_ENABLED=1
SCOUT_FS_ROOT=/
SCOUT_FS_ALLOW_ABSOLUTE=1
SCOUT_AUDIO_SAMPLE_RATE=16000
SCOUT_AUDIO_CHANNELS=1
SCOUT_BOOT_CAMERA=1
# Optional explicit webcam/mic binding:
# SCOUT_VIDEO_DEVICE_ID=
# SCOUT_AUDIO_DEVICE_ID=
SCOUT_VIDEO_LABEL_HINT=nexigo n60
SCOUT_AUDIO_LABEL_HINT=nexigo n60

# Runtime server port
PORT=8787
