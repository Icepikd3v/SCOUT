# Required for live OpenAI responses
OPENAI_API_KEY=

# Optional. Keep configurable so we can swap models quickly.
OPENAI_MODEL=gpt-4o-mini
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_PROFILE=companion
OPENAI_TTS_VOICE=shimmer
OPENAI_TTS_STYLE=warm and human, expressive but calm, natural phrasing, subtle pauses, never robotic or monotone
OPENAI_TTS_SPEED=0.96
OPENAI_TRANSCRIBE_MODEL=whisper-1
OPENAI_VISION_MODEL=gpt-4o-mini
OPENAI_STT_ENGLISH_ONLY=1

# Runtime server port
PORT=8787

# Optional engine routing
AI_PROVIDER=auto
AI_ROUTING_POLICY=cloud_first
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_MODEL_GENERAL=llama3.1:8b
OLLAMA_MODEL_TRAINING=llama3.1:8b
OLLAMA_MODEL_SAFETY=llama3.1:8b
OLLAMA_MODEL_RACE=llama3.1:8b
OLLAMA_MODEL_FOCUS=llama3.1:8b
OPENAI_MODEL_GENERAL=gpt-4o-mini
OPENAI_MODEL_TRAINING=gpt-4o-mini
OPENAI_MODEL_SAFETY=gpt-4o-mini
OPENAI_MODEL_RACE=gpt-4o-mini
OPENAI_MODEL_FOCUS=gpt-4o-mini
LIVE_CACHE_ENABLED=1
LIVE_CACHE_TTL_MS=120000
LIVE_CACHE_MAX_ENTRIES=600

# Admin protection for filesystem/motion control APIs
# If set, send this token in `x-scout-token` or `Authorization: Bearer <token>`
SCOUT_ADMIN_TOKEN=
SCOUT_FS_ENABLED=1
SCOUT_FS_ROOT=.
SCOUT_FS_ALLOW_ABSOLUTE=0

# Optional explicit webcam/mic binding on Pi (set from `v4l2-ctl`/`arecord` checks)
SCOUT_BOOT_CAMERA=1
# SCOUT_VIDEO_DEVICE_ID=
# SCOUT_AUDIO_DEVICE_ID=
SCOUT_VIDEO_LABEL_HINT=nexigo n60
SCOUT_AUDIO_LABEL_HINT=nexigo n60
SCOUT_AUDIO_SAMPLE_RATE=16000
SCOUT_AUDIO_CHANNELS=1
